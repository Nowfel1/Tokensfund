# ---- THORChain ----
THORNODE_URL=https://thornode.ninerealms.com
# 2% affiliate fee paid to your THORName (200 basis points). Both must be set.
THOR_AFFILIATE=your-thorname
THOR_AFFILIATE_BPS=200

# ---- NEAR Intents (1Click) ----
NEAR_1CLICK_URL=https://1click.chaindefuser.com
# Register at https://partners.near-intents.org for a JWT (fee attribution + skips 0.2% no-key fee).
NEAR_1CLICK_JWT=
# appFees is split 50/50 with the 1Click protocol. 400 = user pays 2%, you net ~2% after... no:
#   fee=400 -> user pays 4% total, you net 2%.  fee=200 -> user pays 2%, you net 1%.
# Set to match what you actually want to net:
NEAR_APP_FEE_BPS=400
NEAR_FEE_RECIPIENT=your-wallet.near

# ---- Chainflip ----
CHAINFLIP_NETWORK=mainnet
# Requires a running broker to collect commission. 200 = 2%.
CHAINFLIP_BROKER_URL=
CHAINFLIP_COMMISSION_BPS=200
