# ---- THORChain ----
THORNODE_URL= https://gateway.liquify.com/chain/thorchain_api
# 2% affiliate fee paid to your THORName (200 basis points). Both must be set.
THOR_AFFILIATE=TKF
THOR_AFFILIATE_BPS=200

# ---- NEAR Intents (1Click) ----
NEAR_1CLICK_URL=https://1click.chaindefuser.com
# Register at https://partners.near-intents.org for a JWT (fee attribution + skips 0.2% no-key fee).
NEAR_1CLICK_JWT=eyJhbGciOiJSUzI1NiIsInR5cCI6IkpXVCIsImtpZCI6IjIwMjUtMDEtMTItdjEifQ
# IMPORTANT: appFees on 1Click is split 50/50 with the protocol, so this value
# is the TOTAL the user pays, and you net HALF of it:
#   NEAR_APP_FEE_BPS=200  -> user pays 2% total, you net 1%   <-- keeps user-facing fee flat at 2%
#   NEAR_APP_FEE_BPS=400  -> user pays 4% total, you net 2%   (breaks the "flat 2%" promise — do not use)
# We keep the USER-FACING fee consistent at 2% across all providers.
NEAR_APP_FEE_BPS=200
NEAR_FEE_RECIPIENT=4e765bb660a5b2daac86548fd81381cfebab6446b559a62d801391dfe754d654

# ---- Chainflip ----
CHAINFLIP_NETWORK=mainnet
# Requires a running broker to collect commission. 200 = 2%.
CHAINFLIP_BROKER_URL=https://broker.tokensfund.xyz
CHAINFLIP_COMMISSION_BPS=200
